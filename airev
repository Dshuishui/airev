#!/usr/bin/env bash
# airev — AI code review before you push. A thin wrapper over the AI CLI you
# already have logged in (claude / codex / gemini / copilot). No API keys, runs
# locally, advisory by default. v0.1 (placeholder name).
set -uo pipefail
AIREV_VERSION="0.7.0"
AIREV_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

_root() { git rev-parse --show-toplevel 2>/dev/null; }

# Load repo config (.airev.conf: shell key=value, e.g. CLI=claude BASE=origin/main)
_load_conf() {
  local root; root="$(_root)" || return 0
  [ -n "$root" ] && [ -f "$root/.airev.conf" ] && . "$root/.airev.conf" || true
}

# CLI resolution: --cli flag > $AIREV_CLI > conf CLI= > autodetect
_resolve_cli() {
  local pick="${1:-}"
  [ -n "$pick" ] && { echo "$pick"; return; }
  [ -n "${AIREV_CLI:-}" ] && { echo "$AIREV_CLI"; return; }
  [ -n "${CLI:-}" ] && { echo "$CLI"; return; }
  local c
  for c in claude codex gemini copilot; do
    command -v "$c" >/dev/null 2>&1 && { echo "$c"; return; }
  done
  echo ""
}

# Run the chosen CLI: instruction as arg, diff arrives on stdin.
_run_cli() {
  local cli="$1" instruction="$2" diff; diff="$(cat)"
  case "$cli" in
    claude)  printf '%s' "$diff" | claude -p --output-format text "$instruction" ;;
    codex)   codex exec "$instruction"$'\n\n'"$diff" ;;
    gemini)  printf '%s' "$diff" | gemini -p "$instruction" ;;
    copilot) printf '%s' "$diff" | copilot -p "$instruction" ;;
    *) echo "airev: unknown CLI '$cli' (supported: claude codex gemini copilot)" >&2; return 2 ;;
  esac
}

_default_guidelines() {
  cat <<'EOF'
You are a senior engineer reviewing a git diff before it is pushed. Your job is to
find real defects — not to praise, summarize, or restate the code.

Method — reason, don't guess:
For each change, work out what the code is supposed to do, then actively try to
break it: construct a concrete input or state that makes it crash or return a wrong
result. Report a finding ONLY when you can name that trigger — prefer
"with an empty list, line 42 raises IndexError" over "this looks risky". If you
cannot construct a failing case, do not report it. This keeps signal high.

What to look for, most important first:
  - correctness & edge cases: empty / null / zero / negative / very large inputs,
    boundaries, off-by-one, wrong operator, concurrency, branches with no coverage
  - intent: does the change actually do what it claims (function name, commit, context)?
  - failure handling: unhandled errors, leaked resources, inconsistent state on partial failure
  - security: injection, secrets in code, missing authorization, unsafe deserialization
  - contract: breaking change to a signature / API / output that other code depends on
  - tests: are the new paths covered, and do the assertions check the RIGHT thing?
  - performance: N+1 queries, unbounded growth, needless work in a hot path
  - maintainability: dead code, confusing names, duplication (lower priority)

Severity — begin EVERY finding line with one tag, then file:line:
  [P0]  correctness bug, data loss, or security hole — must fix before push
  [P1]  likely bug, missing error handling, or a risky edge case — should fix
  [P2]  style, naming, dead code, minor simplification — nice to have

Rules:
  - one finding per line, e.g.:  [P1] path/to/file.py:17  <what breaks, then the fix>
  - skip anything on a source line containing the marker `airev-ignore` (author accepted it)
  - no praise, no summary, no restating unchanged code
  - if the diff has no real problems, reply with exactly: LGTM
EOF
}

_guidelines() {
  local root; root="$(_root)"
  # explicit airev rules win — the user owns the whole prompt
  if [ -n "$root" ] && [ -f "$root/.airev/guidelines.md" ]; then
    cat "$root/.airev/guidelines.md"; return
  fi
  # no airev-specific rules: keep the severity/format preamble, then fold in the
  # house rules the repo already has (first hit) so output stays [P0/P1/P2].
  _default_guidelines
  local f
  for f in AGENTS.md CLAUDE.md .cursorrules .github/copilot-instructions.md; do
    if [ -n "$root" ] && [ -f "$root/$f" ]; then
      printf '\n\nProject-specific rules (from %s) — apply where relevant:\n\n' "$f"
      cat "$root/$f"
      return
    fi
  done
}

# sha of stdin (portable): used to skip re-reviewing an unchanged diff.
_hash() {
  if command -v shasum >/dev/null 2>&1; then shasum | cut -d' ' -f1
  elif command -v sha1sum >/dev/null 2>&1; then sha1sum | cut -d' ' -f1
  else cksum | cut -d' ' -f1; fi
}

# Drop findings the author has silenced with an inline `airev-ignore` marker.
# Deterministic backstop to the prompt instruction: for each [P?] finding we pull
# file:line out of the text and, if that source line carries the marker, drop it.
# A stream filter — keeps output live. Non-finding lines (LGTM, notes) pass through.
_filter_ignored() {
  local root; root="$(_root)"
  local line path ln src
  while IFS= read -r line; do
    if [[ "$line" == *'[P'* ]] && [[ "$line" =~ ([A-Za-z0-9_./-]+):([0-9]+) ]]; then
      path="${BASH_REMATCH[1]}"; ln="${BASH_REMATCH[2]}"
      if [ -n "$root" ] && [ -f "$root/$path" ]; then
        src="$(sed -n "${ln}p" "$root/$path" 2>/dev/null)"
        case "$src" in *airev-ignore*) continue ;; esac
      fi
    fi
    printf '%s\n' "$line"
  done
}

# Second-pass instruction for --deep: hand the model the first-pass findings and
# make it keep only what it can back with a concrete trigger, add what was missed,
# and merge duplicates. Output contract is identical to a normal review.
_deep_verify_guide() {
  local pass1="$1"; [ -n "$pass1" ] || pass1="(none)"
  cat <<EOF
You are doing a rigorous SECOND-PASS code review. The git diff is on stdin. A first
pass produced these findings:

--- first pass ---
$pass1
--- end first pass ---

Produce the FINAL review of the diff:
  - KEEP a finding only if you can name a concrete input or state that triggers it
    (e.g. "with an empty list, line 42 raises IndexError"). Drop vague/unprovable ones.
  - ADD any correctness or security bug the first pass missed, proven the same way.
  - Merge duplicates; keep the highest applicable severity.

Output (unchanged): one finding per line starting with [P0], [P1] or [P2] and file:line;
ignore any source line containing airev-ignore; if nothing real remains, reply: LGTM
EOF
}

cmd_review() {
  local cli_flag="" base_flag="" gate=0 json=0 confirm=0 nocache=0 clevel_flag="" wt=0 deep=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --cli)           cli_flag="$2"; shift 2 ;;
      --base)          base_flag="$2"; shift 2 ;;
      --gate)          gate=1; shift ;;
      --json)          json=1; shift ;;
      --confirm)       confirm=1; shift ;;          # interactive: ask before push
      --confirm-level) clevel_flag="$2"; shift 2 ;; # p0 | p1 | any (when to prompt)
      --no-cache)      nocache=1; shift ;;
      --deep)          deep=1; shift ;;             # two-pass: review, then verify each finding
      --worktree)      wt=1; shift ;;               # review base..working tree (used by fix)
      *) echo "airev review: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  _load_conf
  # when --confirm prompts: p0 (only P0) | p1 (P0/P1) | any (incl P2). Default any.
  local clevel="${clevel_flag:-${AIREV_CONFIRM_LEVEL:-${CONFIRM_LEVEL:-any}}}"

  local cli; cli="$(_resolve_cli "$cli_flag")"
  [ -z "$cli" ] && { echo "airev: no AI CLI found. Install one (claude/codex/gemini/copilot) or pass --cli." >&2; return 3; }
  command -v "$cli" >/dev/null 2>&1 || { echo "airev: CLI '$cli' not on PATH." >&2; return 3; }

  # diff range (what will be pushed). `diffspec` is the real git arg; `range` is
  # the human label (becomes "working tree" on the on-demand fallback below).
  local base range diffspec
  base="${base_flag:-${BASE:-}}"
  if [ -n "$base" ]; then range="$base...HEAD"
  elif range_up="$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)"; then range="$range_up...HEAD"
  else range="origin/main...HEAD"; fi
  diffspec="$range"
  # --worktree: review the base vs the working tree (committed + uncommitted), so
  # `airev fix` can see the edits it just applied. `git diff <ref>` (no ...) does this.
  if [ "$wt" -eq 1 ]; then
    diffspec="${diffspec%...HEAD}"; [ -n "$diffspec" ] || diffspec="HEAD"
    range="$diffspec..worktree"
  fi

  # cost guard 1: exclude noisy / generated paths (lock files, builds, binaries)
  local ignore="${IGNORE:-*.lock package-lock.json yarn.lock pnpm-lock.yaml *.min.js *.min.css dist/* build/* out/* node_modules/* vendor/* *.svg *.png *.jpg *.jpeg *.gif *.pdf *.snap}"
  local -a excl=(); local pat
  for pat in $ignore; do excl+=( ":(exclude)$pat" ); done

  # wider context than git's default -U3 so the model sees the imports / guards /
  # types around each hunk — kills "no guard" style false positives. --deep widens
  # it further (whole functions in view) unless CONTEXT_LINES is set explicitly.
  local ctx="${CONTEXT_LINES:-20}"
  [ "$deep" -eq 1 ] && [ -z "${CONTEXT_LINES:-}" ] && ctx=60
  local diff; diff="$(git diff -U"$ctx" "$diffspec" -- . "${excl[@]}" 2>/dev/null)"
  # On-demand review with nothing committed yet? fall back to the working tree so
  # `airev review` still shows something. Pre-push (--confirm) and CI (--gate/
  # --json) stay commit-only — they review exactly what is being pushed.
  if [ -z "$diff" ] && [ "$confirm" -eq 0 ] && [ "$gate" -eq 0 ] && [ "$json" -eq 0 ]; then
    diff="$(git diff -U"$ctx" HEAD -- . "${excl[@]}" 2>/dev/null)"
    [ -n "$diff" ] && { diffspec="HEAD"; range="working tree"; }
  fi
  [ -z "$diff" ] && { echo "airev: no reviewable changes vs $range (after ignore rules)."; return 0; }

  local files_all; files_all="$(printf '%s\n' "$diff" | sed -n 's#^diff --git a/\(.*\) b/.*#\1#p')"
  local nfiles; nfiles="$(printf '%s\n' "$files_all" | grep -c .)"

  # cost guard 2: cap very large diffs so one push can't run away on tokens/time
  local max_lines="${MAX_DIFF_LINES:-1500}" nlines truncated=0 dropped=""
  nlines="$(printf '%s\n' "$diff" | wc -l | tr -d ' ')"
  if [ "$nlines" -gt "$max_lines" ]; then
    diff="$(printf '%s\n' "$diff" | head -n "$max_lines")"
    truncated=1
    local kept; kept="$(printf '%s\n' "$diff" | sed -n 's#^diff --git a/\(.*\) b/.*#\1#p' | grep -c .)"
    dropped="$(printf '%s\n' "$files_all" | tail -n +"$((kept+1))" | paste -sd' ' -)"
  fi

  [ "$json" -eq 0 ] && echo "── airev review (cli=$cli, range=$range, ${nlines} diff lines$([ "$truncated" = 1 ] && echo ", truncated to $max_lines")) ──"

  local guide; guide="$(_guidelines)"

  # --deep: two passes. Pass 1 finds; then rebuild the instruction so the main
  # (streamed) pass re-examines the diff — keeping only findings backed by a
  # concrete failing input, adding missed bugs, merging duplicates. Never cached.
  if [ "$deep" -eq 1 ]; then
    nocache=1
    [ "$json" -eq 0 ] && printf 'airev: deep review — pass 1/2 (finding)…\n' >&2
    local pass1; pass1="$(printf '%s' "$diff" | _run_cli "$cli" "$guide" 2>/dev/null | _filter_ignored)"
    guide="$(_deep_verify_guide "$pass1")"
    [ "$json" -eq 0 ] && printf 'airev: deep review — pass 2/2 (verifying)…\n' >&2
  fi

  # cache: skip the CLI entirely when this exact diff+rules+cli was just reviewed.
  local cachedir; cachedir="$(_review_dir)"
  local key=""
  [ -n "$cachedir" ] && key="$(printf '%s' "$cli|$guide|$diff" | _hash)"

  local out cached=0
  if [ "$json" -eq 0 ] && [ "$nocache" -eq 0 ] && [ -n "$key" ] \
     && [ -f "$cachedir/last.sha" ] && [ "$(cat "$cachedir/last.sha" 2>/dev/null)" = "$key" ] \
     && [ -f "$cachedir/last.out" ]; then
    out="$(cat "$cachedir/last.out")"; cached=1
    echo "airev: unchanged since last review — cached result (--no-cache to re-run):"
    printf '%s\n' "$out"
  else
    [ "$json" -eq 0 ] && [ "$deep" -eq 0 ] && printf 'airev: reviewing %s file(s) via %s… (Ctrl-C to skip)\n' "$nfiles" "$cli" >&2
    if [ "$json" -eq 1 ]; then
      out="$(printf '%s' "$diff" | _run_cli "$cli" "$guide" 2>/dev/null | _filter_ignored)" || { echo '[]'; return 0; }
    else
      # stream findings live as they arrive (minus airev-ignore'd ones), while
      # still capturing them for the save / parse / gate / confirm steps below.
      local tmp; tmp="$(mktemp "${TMPDIR:-/tmp}/airev.XXXXXX" 2>/dev/null || echo "$cachedir/last.tmp")"
      printf '%s' "$diff" | _run_cli "$cli" "$guide" 2>/dev/null | _filter_ignored | tee "$tmp"
      local rc="${PIPESTATUS[1]}"
      out="$(cat "$tmp" 2>/dev/null)"; rm -f "$tmp"
      if [ "$rc" -ne 0 ] && [ -z "$out" ]; then
        echo "airev: '$cli' failed (not logged in?). Skipping."; return 0
      fi
    fi
    [ "$json" -eq 0 ] && [ "$deep" -eq 0 ] && [ -n "$key" ] && { printf '%s' "$out" > "$cachedir/last.out" 2>/dev/null; printf '%s' "$key" > "$cachedir/last.sha" 2>/dev/null; }
  fi

  if [ "$json" -eq 1 ]; then
    printf '%s\n' "$out" | _to_json; echo
    return 0   # CI mode: consumed via PR comment / tooling; nothing saved locally
  fi

  [ "$truncated" = 1 ] && {
    echo "airev: note — diff truncated to $max_lines lines (raise MAX_DIFF_LINES to review more)."
    [ -n "$dropped" ] && echo "airev: not reviewed (truncated): $dropped"
  }
  echo "──────────────────────────────────────────"

  # save the result locally (in .git/, never committed) for later viewing
  local rf; rf="$(_review_file)"
  if [ -n "$rf" ]; then
    { echo "# airev review — $(date '+%Y-%m-%d %H:%M:%S')"; echo "range: $range | cli: $cli"; echo; printf '%s\n' "$out"; } > "$rf"
    echo "airev: saved → .git/airev/last-review.md  (view: airev last)"
  fi

  local has_p0=0 has_hi=0 has_any=0
  printf '%s' "$out" | grep -qE '\[P0\]' && has_p0=1
  printf '%s' "$out" | grep -qE '\[P0\]|\[P1\]' && has_hi=1
  printf '%s' "$out" | grep -qE '\[P0\]|\[P1\]|\[P2\]' && has_any=1

  # gate (CI / non-interactive): fail hard on P0/P1 only (don't block PRs on P2 nits)
  if [ "$gate" -eq 1 ] && [ "$has_hi" -eq 1 ]; then
    echo "airev: P0/P1 findings — gate FAILED." >&2
    return 1
  fi

  # confirm (local pre-push): let YOU decide — fix first, or push anyway. WHEN it
  # prompts is your call via CONFIRM_LEVEL / --confirm-level: p0 | p1 | any
  # (default any = even a P2 nit stops to ask). Only prompts on a real terminal;
  # CI / scripts fall through without blocking.
  local trip=0
  case "$clevel" in
    p0)    [ "$has_p0" -eq 1 ] && trip=1 ;;
    p1)    [ "$has_hi" -eq 1 ] && trip=1 ;;
    any|*) [ "$has_any" -eq 1 ] && trip=1 ;;
  esac
  if [ "$confirm" -eq 1 ] && [ "$trip" -eq 1 ] && [ -t 1 ] && [ -e /dev/tty ]; then
    printf 'airev: findings above. Push anyway? [y/N] ' > /dev/tty
    local ans=""; read -r ans < /dev/tty || ans=""
    case "$ans" in
      y|Y|yes|YES) return 0 ;;
      *) echo "airev: push aborted — improve the code and push again (or 'git push --no-verify')." > /dev/tty; return 1 ;;
    esac
  fi
  return 0
}

# Where the last local review is stored: inside .git/ (never committed, per-clone).
_review_dir() {
  local gd; gd="$(git rev-parse --git-dir 2>/dev/null)" || return 0
  [ -n "$gd" ] && mkdir -p "$gd/airev" 2>/dev/null && echo "$gd/airev"
}
_review_file() { local d; d="$(_review_dir)" && [ -n "$d" ] && echo "$d/last-review.md"; }

cmd_last() {
  local rf; rf="$(_review_file)"
  if [ -n "$rf" ] && [ -f "$rf" ]; then cat "$rf"; else echo "airev: no saved review yet (run 'airev review')."; fi
}

# Hand the findings to an agentic CLI so it edits the working tree to resolve them.
# Only claude / codex can apply edits; edits are left UNCOMMITTED for you to inspect.
_apply_fix() {
  local cli="$1" rf="$2"
  local prompt="You are fixing code-review findings in this repository's working tree.
Apply the smallest edits that resolve each finding below, then stop. Do NOT commit,
do NOT push, do NOT touch anything unrelated. Findings:

$(cat "$rf")"
  case "$cli" in
    claude) claude -p --permission-mode acceptEdits "$prompt" ;;
    codex)  codex exec --full-auto "$prompt" ;;
    *) echo "airev fix: '--fix' needs an agentic CLI (claude or codex); got '$cli'." >&2; return 2 ;;
  esac
}

cmd_fix() {
  local cli_flag="" base_flag="" max=3
  while [ $# -gt 0 ]; do
    case "$1" in
      --cli)   cli_flag="$2"; shift 2 ;;
      --base)  base_flag="$2"; shift 2 ;;
      --max)   max="$2"; shift 2 ;;
      *) echo "airev fix: unknown arg '$1'" >&2; return 2 ;;
    esac
  done
  _load_conf
  local cli; cli="$(_resolve_cli "$cli_flag")"
  case "$cli" in
    claude|codex) : ;;
    "") echo "airev: no AI CLI found. Install claude or codex, or pass --cli." >&2; return 3 ;;
    *)  echo "airev fix: '--fix' needs an agentic CLI (claude or codex), not '$cli'." >&2; return 2 ;;
  esac
  command -v "$cli" >/dev/null 2>&1 || { echo "airev: CLI '$cli' not on PATH." >&2; return 3; }

  local rf; rf="$(_review_file)"
  local i=1
  while [ "$i" -le "$max" ]; do
    echo "── airev fix: pass $i/$max ──"
    # review the base vs the working tree so each pass sees the prior fixes
    cmd_review --cli "$cli" ${base_flag:+--base "$base_flag"} --worktree --no-cache
    [ -n "$rf" ] && [ -f "$rf" ] || { echo "airev fix: no review to act on."; return 1; }
    if ! grep -qE '\[P0\]|\[P1\]' "$rf"; then
      echo "airev fix: no P0/P1 findings left ✔  (review the uncommitted edits, then commit)"
      return 0
    fi
    if [ "$i" -eq "$max" ]; then
      echo "airev fix: reached max passes ($max) — some findings remain. See 'airev last'."
      return 1
    fi
    echo "airev fix: applying fixes with ${cli}…"
    _apply_fix "$cli" "$rf" || { echo "airev fix: fixer failed (not logged in, or CLI can't edit)."; return 1; }
    i=$((i + 1))
  done
}

# Parse [P0]/[P1]/[P2] lines (stdin) into a JSON array of findings.
_to_json() {
  local first=1 line sev rest
  printf '['
  while IFS= read -r line; do
    case "$line" in
      \[P0\]*|\[P1\]*|\[P2\]*)
        sev="${line:1:2}"; rest="${line#*] }"
        rest="${rest//\\/\\\\}"; rest="${rest//\"/\\\"}"
        [ "$first" -eq 1 ] || printf ','
        printf '{"severity":"%s","finding":"%s"}' "$sev" "$rest"
        first=0 ;;
    esac
  done
  printf ']'
}

# Re-download the latest airev over this same file (borrowed from codegraph's `upgrade`).
cmd_upgrade() {
  local dest; dest="$(command -v airev 2>/dev/null || echo "$AIREV_HOME/airev")"
  echo "airev: upgrading $dest ..."
  curl -fsSL "https://raw.githubusercontent.com/Dshuishui/airev/main/airev" -o "$dest.tmp" \
    && chmod +x "$dest.tmp" && mv "$dest.tmp" "$dest" \
    && echo "airev: now $("$dest" version)" \
    || { echo "airev: upgrade failed." >&2; rm -f "$dest.tmp"; return 1; }
}

cmd_init() {
  local root; root="$(_root)" || { echo "airev: not a git repo." >&2; return 1; }
  mkdir -p "$root/.airev" "$root/.git/hooks"
  # rules file
  [ -f "$root/.airev/guidelines.md" ] || _default_guidelines > "$root/.airev/guidelines.md"
  # config
  [ -f "$root/.airev.conf" ] || printf '# airev config\nCLI=%s\n# BASE=origin/main\n# CONFIRM_LEVEL=any          # when pre-push prompts: p0 | p1 | any\n# CONTEXT_LINES=20           # diff context sent to the model (more = fewer false positives)\n# MAX_DIFF_LINES=1500        # cap huge diffs (cost guard)\n# IGNORE="*.lock dist/* *.min.js"  # extra paths to skip\n' "$(_resolve_cli)" > "$root/.airev.conf"
  # hook -> calls this same airev binary
  cat > "$root/.git/hooks/pre-push" <<EOF
#!/usr/bin/env bash
# Review before push. On P0/P1 it asks whether to proceed (fix first, or push
# anyway). Non-interactive shells fall through without blocking.
exec "$AIREV_HOME/airev" review --confirm
EOF
  chmod +x "$root/.git/hooks/pre-push"
  echo "airev: installed pre-push hook + .airev/guidelines.md + .airev.conf in $root"
  echo "airev: default CLI = $(_resolve_cli) (edit .airev.conf to change)"
}

case "${1:-help}" in
  review)  shift; cmd_review "$@" ;;
  fix)     shift; cmd_fix "$@" ;;
  init)    shift; cmd_init "$@" ;;
  last)    shift; cmd_last "$@" ;;
  upgrade) shift; cmd_upgrade "$@" ;;
  version|--version|-v) echo "airev $AIREV_VERSION" ;;
  help|--help|-h|*)
    cat <<EOF
airev $AIREV_VERSION — AI code review before you push (uses your logged-in AI CLI)

  airev init                     install pre-push hook + config in this repo
  airev review [opts]            review pending changes now
      --cli <name>   claude | codex | gemini | copilot  (else \$AIREV_CLI, conf, autodetect)
      --base <ref>   diff base (default: upstream, else origin/main)
      --confirm      ask before proceeding when findings trip CONFIRM_LEVEL (pre-push hook)
      --confirm-level <p0|p1|any>   when --confirm prompts (default any; also CONFIRM_LEVEL=)
      --gate         exit non-zero on [P0]/[P1] (block push / fail CI, no prompt)
      --json         emit findings as JSON (for CI / tooling)
      --no-cache     re-run even if the diff is unchanged since the last review
      --deep         two-pass: review, then verify each finding (slower, higher signal)
  airev fix [opts]               review, let claude/codex fix the findings, re-review (loop)
      --cli <name>   claude | codex   (agentic CLI that can edit files)
      --base <ref>   diff base (default: upstream, else origin/main)
      --max <n>      max review→fix passes (default 3). Edits are left uncommitted.
  airev last                     show the last saved review (.git/airev/last-review.md)
  airev upgrade                  update airev in place to the latest version
  airev version

Config: repo .airev.conf (CLI=, BASE=, CONFIRM_LEVEL=, CONTEXT_LINES=) and
        .airev/guidelines.md (review rules; falls back to AGENTS.md / CLAUDE.md).
Silence a false positive: add an 'airev-ignore' marker on that source line.
CI: run 'airev review --base origin/\$BASE --gate' in a PR job (see README).
EOF
    ;;
esac
